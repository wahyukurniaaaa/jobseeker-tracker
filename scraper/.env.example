# URL Webhook n8n yang menerima payload lowongan (WAJIB)
N8N_WEBHOOK_URL=https://n8n.wahyukurnia.com/webhook/job-scraper

# Kata kunci pencarian lowongan (opsional, default: "Customer Service").
# Bisa lebih dari satu, dipisah koma — cocok untuk profil CS + Admin.
SEARCH_KEYWORD=Customer Service,Admin,Data Entry,Customer Experience

# Maksimum lowongan per sumber (opsional, default: 10)
MAX_JOBS_PER_SOURCE=10
